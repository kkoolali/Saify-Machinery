rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email.matches("(?i)^aliasgar\\.saify@gmail\\.com$") && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidCategory(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 256 &&
             data.icon is string && data.icon.size() <= 128 &&
             data.color is string && data.color.size() <= 128 &&
             data.items is list && data.items.size() <= 50 &&
             data.images is list && data.images.size() <= 20;
    }

    function isValidFeaturedProduct(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 256 &&
             data.description is string && data.description.size() <= 1000 &&
             data.image is string && data.image.size() <= 1024 &&
             data.linkText is string && data.linkText.size() <= 128 &&
             data.categoryHash is string && data.categoryHash.size() <= 512;
    }

    function isValidTestimonial(data) {
      return data.name is string && data.name.size() <= 128 &&
             data.text is string && data.text.size() <= 2000 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5;
    }

    function isValidInquiry(data) {
      return data.name is string && data.name.size() <= 256 &&
             data.phone is string && data.phone.size() <= 32 &&
             data.message is string && data.message.size() <= 5000 &&
             data.createdAt == request.time;
    }

    function isValidOrder(data) {
      return data.customer is map &&
             data.customer.name is string && data.customer.name.size() <= 256 &&
             data.customer.email is string && data.customer.email.size() <= 256 &&
             data.customer.phone is string && data.customer.phone.size() <= 32 &&
             data.customer.address is string && data.customer.address.size() <= 1024 &&
             data.items is list && data.items.size() >= 1 && data.items.size() <= 100 &&
             data.total is string && data.total.size() <= 64 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.createdAt is number;
    }

    function isValidBrand(data) {
      return data.name is string && data.name.size() <= 256 &&
             data.logo is string && data.logo.size() <= 2048 &&
             (!('website' in data) || (data.website is string && data.website.size() <= 1024));
    }

    function isValidSiteConfig(id, data) {
      return (id == 'global' && 
               data.storeName is string && data.storeName.size() <= 256 &&
               data.gstNumber is string && data.gstNumber.size() <= 128 &&
               data.phone is string && data.phone.size() <= 64 &&
               data.whatsapp is string && data.whatsapp.size() <= 64 &&
               data.email is string && data.email.size() <= 256 &&
               data.address is string && data.address.size() <= 1024 &&
               data.footerDescription is string && data.footerDescription.size() <= 2000 &&
               data.socials is map
             ) ||
             (id == 'hero' && 
               data.title is string && data.title.size() <= 512 &&
               data.description is string && data.description.size() <= 2000 &&
               data.backgroundImage is string && data.backgroundImage.size() <= 2048 &&
               data.ctaText is string && data.ctaText.size() <= 128 &&
               data.badgeText is string && data.badgeText.size() <= 512
             ) ||
             (id == 'about' && 
               data.badge is string && data.badge.size() <= 256 &&
               data.title is string && data.title.size() <= 512 &&
               data.description is string && data.description.size() <= 5000 &&
               data.experienceTitle is string && data.experienceTitle.size() <= 512 &&
               data.experienceDescription is string && data.experienceDescription.size() <= 5000 &&
               data.image is string && data.image.size() <= 2048 &&
               data.ownerName is string && data.ownerName.size() <= 256
             );
    }

    function isValidIndividualProduct(data) {
      return data.title is string && data.title.size() <= 256 &&
             data.description is string && data.description.size() <= 6000 &&
             data.categoryId is string && data.categoryId.size() <= 128 &&
             data.imageUrl is string && data.imageUrl.size() <= 2048 &&
             data.featured is bool &&
             (!('price' in data) || (data.price is string && data.price.size() <= 128)) &&
             (!('enquiryOnly' in data) || (data.enquiryOnly is bool)) &&
             (!('images' in data) || (data.images is list && data.images.size() <= 20)) &&
             (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.size() <= 2048)) &&
             (!('videoTitle' in data) || (data.videoTitle is string && data.videoTitle.size() <= 256)) &&
             (!('seoTitle' in data) || (data.seoTitle is string && data.seoTitle.size() <= 256)) &&
             (!('seoDescription' in data) || (data.seoDescription is string && data.seoDescription.size() <= 1000)) &&
             (!('seoKeywords' in data) || (data.seoKeywords is string && data.seoKeywords.size() <= 1000)) &&
             (!('variantLabel' in data) || (data.variantLabel is string && data.variantLabel.size() <= 256)) &&
             (!('variants' in data) || (data.variants is list && data.variants.size() <= 50)) &&
             (!('createdAt' in data) || (data.createdAt is number)) &&
             (data.updatedAt is number);
    }

    // --- Match Rules ---

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidIndividualProduct(incoming()) && isValidId(productId);
    }

    match /site_config/{configId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSiteConfig(configId, incoming()) && isValidId(configId);
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin() && isValidBrand(incoming()) && isValidId(brandId);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCategory(incoming()) && isValidId(categoryId);
    }

    match /featured_products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidFeaturedProduct(incoming()) && isValidId(productId);
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin() && isValidTestimonial(incoming()) && isValidId(testimonialId);
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(incoming()) && isValidId(inquiryId);
      allow read, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(incoming()) && isValidId(orderId);
      allow read, update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      // Only admins can see who else is an admin or add new ones
      allow read, write: if isAdmin();
      // Allow initial setup check for the specific user
      allow get: if isSignedIn() && request.auth.uid == adminId;
    }
  }
}
