{
  "entities": {
    "Category": {
      "title": "Product Category",
      "description": "A category of products with a gallery and list of features.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "color": { "type": "string", "description": "Tailwind color class for the icon background" },
        "items": { "type": "array", "items": { "type": "string" } },
        "images": { "type": "array", "items": { "type": "string" } },
        "order": { "type": "number" }
      },
      "required": ["id", "title", "icon", "items", "images"]
    },
    "FeaturedProduct": {
      "title": "Featured Product",
      "description": "Products highlighted on the homepage.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "fallbackUrl": { "type": "string" },
        "linkText": { "type": "string" },
        "categoryHash": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "title", "description", "image", "linkText", "categoryHash"]
    },
    "Testimonial": {
      "title": "Customer Testimonial",
      "description": "A review from a customer displayed in the testimonials section.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "avatar": { "type": "string" },
        "rating": { "type": "number" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "rating", "text"]
    },
    "Inquiry": {
      "title": "Customer Inquiry",
      "description": "A message submitted through the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "message", "createdAt"]
    },
    "Admin": {
      "title": "Administrator",
      "description": "A user with administrative access.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "Variant": {
      "title": "Product Variant",
      "description": "A specific selection for a product like size, color, or material.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "e.g. 500 Liters, Blue, Stainless Steel" },
        "price": { "type": "string", "description": "Price override for this variant" },
        "imageUrl": { "type": "string", "description": "Image override for this variant" }
      },
      "required": ["id", "name"]
    },
    "Product": {
      "title": "Catalog Product",
      "description": "A standalone product in the catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "price": { "type": "string" },
        "imageUrl": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "videoUrl": { "type": "string" },
        "videoTitle": { "type": "string" },
        "featured": { "type": "boolean" },
        "enquiryOnly": { "type": "boolean" },
        "variants": { "type": "array", "items": { "$ref": "#/entities/Variant" } },
        "variantLabel": { "type": "string", "description": "e.g. Select Size, Color Selection" },
        "updatedAt": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "description", "categoryId", "imageUrl", "featured"]
    },
    "Order": {
      "title": "Customer Order",
      "description": "An online order placed by a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customer": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          },
          "required": ["name", "email", "phone", "address"]
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productTitle": { "type": "string" },
              "variantId": { "type": "string" },
              "variantName": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "string" },
              "imageUrl": { "type": "string" }
            },
            "required": ["productId", "productTitle", "quantity", "price"]
          }
        },
        "total": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "number" }
      },
      "required": ["customer", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "products": {
        "schema": { "$ref": "#/entities/Product" },
        "description": "Individual items in the store's full catalog."
    },
    "categories": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Product categories shown in the gallery."
    },
    "featured_products": {
      "schema": { "$ref": "#/entities/FeaturedProduct" },
      "description": "Featured products on the landing page."
    },
    "testimonials": {
      "schema": { "$ref": "#/entities/Testimonial" },
      "description": "Customer reviews and testimonials."
    },
    "inquiries": {
      "schema": { "$ref": "#/entities/Inquiry" },
      "description": "Contact form submissions."
    },
    "orders": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Online orders placed via the checkout process."
    },
    "admins": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "List of authorized administrators."
    }
  }
}
